# moshiClaw Panel — Variables de entorno
# Copiá este archivo a .env y ajustá si necesitás.
# Si no lo tocás, el servidor genera credenciales automáticamente al arrancar.

# Puerto del servidor (defecto: 3000)
PORT=3000

# Usuario de login (defecto: agus)
APP_USER=agus

# Contraseña (se genera automáticamente si no la ponés)
# APP_PASSWORD=tu_contraseña_aqui

# JWT Secret (se genera automáticamente)
# JWT_SECRET=secret_aleatorio_muy_largo

# Display X11 para captura de pantalla (normalmente :0 o :1)
DISPLAY=:0

# Shell a usar en la terminal
# SHELL=/bin/bash
